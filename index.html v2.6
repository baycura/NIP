async function showRulesForLang(e){
  var rw=document.getElementById('rulesWrap'),rt=document.getElementById('rulesText'),rc=document.getElementById('rulesCheck');
  if(rc)rc.checked=false;
  if(!e.rules||!rw||!rt){if(rw)rw.style.display='none';return;}
  rw.style.display='block';
  // Check cache first
  if(State.rulesCache[e.id]&&State.rulesCache[e.id][State.lang]){
    rt.textContent=State.rulesCache[e.id][State.lang];return;
  }
  // Show Turkish (original) first
  rt.textContent=e.rules;
  if(State.lang==='tr'){
    if(!State.rulesCache[e.id])State.rulesCache[e.id]={};
    State.rulesCache[e.id].tr=e.rules;return;
  }
  // Translate via Claude API
  rt.textContent=e.rules; // show original while translating
  translateRules(e.id,e.rules,State.lang,rt);
}

async function translateRules(eventId,rulesText,targetLang,el){
  try{
    var langNames={en:'English',ru:'Russian'};
    var response=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        messages:[{role:'user',content:'Translate these event rules to '+langNames[targetLang]+'. Keep the same format and line breaks. Output ONLY the translated text, nothing else:\n\n'+rulesText}]
      })
    });
    var data=await response.json();
    if(data.content&&data.content[0]&&data.content[0].text){
      var translated=data.content[0].text.trim();
      if(!State.rulesCache[eventId])State.rulesCache[eventId]={};
      State.rulesCache[eventId][targetLang]=translated;
      // Only update if user is still on same lang
      if(State.lang===targetLang&&el)el.textContent=translated;
    }
  }catch(e){/* fallback to Turkish already shown */}
}

// ═══ SHEET ═══
function openSheet(){var s=document.getElementById('resSheet');if(s)s.classList.add('open');}
function closeSheet(){var s=document.getElementById('resSheet');if(s)s.classList.remove('open');}
function toggleSheet(){var s=document.getElementById('resSheet');if(s)s.classList.toggle('open');}
function resetSheet(){
  State.selectedEventId=null;State.guestCount=2;
  var cv=document.getElementById('cntVal');if(cv)cv.textContent='2';
  var gw=document.getElementById('guestNamesWrap');if(gw)gw.innerHTML='';
  closeSheet();
}
// Sheet swipe
(function(){
  var startY=0,startX=0,tracking=false;
  document.addEventListener('touchstart',function(e){
    startY=e.touches[0].clientY;startX=e.touches[0].clientX;tracking=true;
  },{passive:true});
  document.addEventListener('touchend',function(e){
    if(!tracking)return;tracking=false;
    var s=document.getElementById('resSheet');if(!s)return;
    var dy=e.changedTouches[0].clientY-startY;
    var dx=Math.abs(e.changedTouches[0].clientX-startX);
    if(dx>Math.abs(dy)||dx>30)return; // ignore horizontal
    if(!s.classList.contains('open')&&dy<-60)openSheet();
    else if(s.classList.contains('open')&&dy>80&&s.scrollTop===0)closeSheet();
  },{passive:true});
})();

