// ═══ BOOT ═══
(async function boot(){
  applyLangText();
  // Handle password reset redirect
  if(location.hash&&location.hash.includes('type=recovery')){G('s-newpw');hideBoot();return;}

  var [sessionRes]=await Promise.all([_SB.auth.getSession(),loadEvents()]);
  var session=sessionRes.data&&sessionRes.data.session;

  _SB.auth.onAuthStateChange(async function(event,newSession){
    State.session=newSession;
    if(event==='SIGNED_IN'&&newSession){
      await loadProfile();
      // Check if profile needs completion (Google login)
      if(State.profile&&!State.profile.phone&&newSession.user.app_metadata&&newSession.user.app_metadata.provider==='google'){
        G('s-complete-profile');
        return;
      }
      afterProfileLoad();
    }
    if(event==='SIGNED_OUT'){State.profile=null;showGuestMode();}
    if(event==='PASSWORD_RECOVERY'){G('s-newpw');}
  });

  if(session){
    State.session=session;
    await loadProfile();
    if(!State.profile){await _SB.auth.signOut();showGuestMode();G('s-customer');hideBoot();return;}
    // Google user without phone = needs completion
    if(!State.profile.phone&&session.user.app_metadata&&session.user.app_metadata.provider==='google'){
      G('s-complete-profile');hideBoot();return;
    }
    afterProfileLoad();
  } else {
    showGuestMode();G('s-customer');
  }
  hideBoot();
  loadBranding();
})();

function hideBoot(){
  var o=document.getElementById('bootOverlay');
  if(!o)return;
  o.classList.add('fade');
  setTimeout(function(){o.classList.add('gone');},550);
}

