  var tier=(TIER_LABELS[State.lang]||TIER_LABELS.tr)[p.tier]||p.tier;
  var attRate=p.total_reservations>0?Math.round((p.total_attended/p.total_reservations)*100):100;

  // Tier progress: bronze 0-149, silver 150-299, gold 300-499, elite 500+
  var tierRanges={bronze:{min:0,max:149},silver:{min:150,max:299},gold:{min:300,max:499},elite:{min:500,max:500}};
  var tr2=tierRanges[p.tier]||tierRanges.bronze;
  var tierPct=p.tier==='elite'?100:Math.min(100,Math.round(((p.trust_score-tr2.min)/(tr2.max-tr2.min+1))*100));
  var nextTier={bronze:'GÜMÜŞ',silver:'ALTIN',gold:'ELİT',elite:'MAX'}[p.tier];
  var tierColor={'bronze':'var(--bronze)','silver':'var(--silver)','gold':'var(--goldtier)','elite':'var(--elite)'}[p.tier]||'var(--white)';

  // Score bars
  function scoreBar(label,val2,max,color,note){
    var pct=Math.min(100,Math.round((val2/max)*100));
    var filled=Math.round(pct/10);
    var bars='';
    for(var i=0;i<10;i++){
      bars+='<span style="display:inline-block;width:18px;height:8px;border-radius:1px;margin-right:2px;background:'+(i<filled?color:'var(--dim)')+'"></span>';
    }
    return '<div style="margin-bottom:14px">'+
      '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">'+
      '<span class="t-label" style="color:var(--muted)">'+label+'</span>'+
      '<span class="t-mono" style="font-size:10px;color:'+color+'">'+val2+(note?' <span style="font-size:8px;color:var(--muted)">'+note+'</span>':'')+'</span>'+
      '</div>'+
      '<div>'+bars+'</div>'+
