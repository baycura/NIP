// ═══ EVENTS ═══
async function loadEvents(){
  showCarouselSkeleton();
  var today=new Date().toISOString().split('T')[0];
  var res=await _SB.from('events').select(
    'id,name,genre,subtitle,date,time,poster_thumb,poster_blur,capacity,approved_count,access_type,min_tier,min_trust,rules,note,status'
  ).eq('status','active').gte('date',today).order('date',{ascending:true});
  State.events=res.data||[];
  renderCarousel();
}

function showCarouselSkeleton(){
  var tr=document.getElementById('cTrack');if(!tr)return;
  tr.innerHTML='<div class="pc" style="flex:0 0 calc(100vw - 60px);max-width:310px"><div class="skel skel-img"></div><div class="skel-meta"><div class="skel skel-line w70"></div><div class="skel skel-line w40"></div></div></div><div class="pc" style="flex:0 0 calc(100vw - 60px);max-width:310px"><div class="skel skel-img"></div><div class="skel-meta"><div class="skel skel-line w70"></div><div class="skel skel-line w40"></div></div></div>';
}

function isMembersOnly(evt){return evt.access_type==='members_only';}
function userIsMember(){return State.profile&&State.profile.status==='approved';}

function canAccess(evt){
  if(isMembersOnly(evt)&&!userIsMember()) return {allowed:false,reason:'members_only'};
  var p=State.profile;
  if(!p) return {allowed:true,guestMode:true}; // guests can access open events
  if(p.trust_score<(evt.min_trust||0)) return {allowed:false,reason:'trust_too_low'};
  if(evt.access_type==='tier_restricted'){
    if(TIER_ORDER.indexOf(p.tier)<TIER_ORDER.indexOf(evt.min_tier||'bronze')) return {allowed:false,reason:'tier_insufficient'};
  }
  if(evt.approved_count>=evt.capacity) return {allowed:false,reason:'full',canWaitlist:true};
  return {allowed:true};
}

function renderCarousel(){
  var tr=document.getElementById('cTrack'),dt=document.getElementById('cDots');
  if(!tr)return;
  State.carouselIndex=0;tr.innerHTML='';dt.innerHTML='';
  if(!State.events.length){tr.innerHTML='<div class="empty" style="width:calc(100vw - 60px)">Yaklaşan etkinlik yok.</div>';return;}
  State.events.forEach(function(e,i){
    var access=canAccess(e);
    var membersOnly=isMembersOnly(e)&&!userIsMember();
    var dLeft=Math.ceil((new Date(e.date+'T00:00:00')-new Date())/86400000);
    var countdown=dLeft>0?(dLeft===1?'Yarın':dLeft+' gün'):'';
    var card=document.createElement('div');
    card.className='pc'+(State.selectedEventId===e.id?' sel':'');
    card.dataset.id=e.id;
    card.addEventListener('click',function(){selEvt(e.id);});
    var imgHtml='<div class="pc-img-wrap">';
    if(e.poster_blur) imgHtml+='<img class="pc-blur" src="'+_esc(e.poster_blur)+'" alt="" aria-hidden="true">';
    if(e.poster_thumb) imgHtml+='<img class="pc-img" src="'+_esc(e.poster_thumb)+'" loading="'+(i<2?'eager':'lazy')+'" decoding="async" alt="'+_esc(e.name)+'" onload="this.classList.add(\'loaded\')">';
    else imgHtml+='<div class="pc-noimg"><span>'+_esc(e.name.substring(0,12))+'</span></div>';
    if(membersOnly){
      imgHtml+='<div class="pc-lock"><div class="pc-lock-title">'+t('membersOnly')+'</div><div class="pc-lock-sub">MEMBERS ONLY</div></div>';
    }
    // Members only badge (always shown if access_type = members_only)
    if(e.access_type==='members_only') imgHtml+='<div class="members-only-badge">MEMBERS ONLY</div>';
    imgHtml+='</div>';
    var meta='<div class="pc-meta"><div class="pc-name">'+_esc(e.name)+'</div><div class="pc-row">';
    if(e.genre) meta+='<span class="pc-genre">'+_esc(e.genre)+'</span>';
    meta+='<span class="pc-date">'+fmtDate(e.date)+(e.time?' · '+e.time:'')+'</span>';
    if(countdown) meta+='<span class="t-mono" style="font-size:7px;color:var(--muted);margin-left:auto">'+countdown+'</span>';
    meta+='</div></div>';
    card.innerHTML=imgHtml+meta+'<div class="pc-ring"></div><div class="pc-chk">✓</div>';
    tr.appendChild(card);
    var dot=document.createElement('div');dot.className='c-dot'+(i===0?' active':'');
    (function(idx){dot.addEventListener('click',function(){State.carouselIndex=idx;updCarousel();});})(i);
    dt.appendChild(dot);
  });
  updCarousel(false);setupSwipe();
}

function updCarousel(anim){
  if(anim===undefined)anim=true;
  var tr=document.getElementById('cTrack');
  var cs=tr?tr.querySelectorAll('.pc'):[];
  if(!cs.length)return;
  var cw=cs[0].offsetWidth+10;
  tr.style.transition=anim?'transform .42s cubic-bezier(.4,0,.2,1)':'none';
  tr.style.transform='translateX(-'+(State.carouselIndex*cw)+'px)';
  document.querySelectorAll('.c-dot').forEach(function(d,i){d.classList.toggle('active',i===State.carouselIndex);});
}

function setupSwipe(){
  var vp=document.getElementById('cVP');if(!vp)return;
  vp.ontouchstart=function(e){State._sx=e.touches[0].clientX;State._drag=true;};
  vp.ontouchmove=function(e){if(!State._drag)return;if(Math.abs(e.touches[0].clientX-State._sx)>10)e.preventDefault();};
  vp.ontouchend=function(e){
    if(!State._drag)return;State._drag=false;
    var dx=e.changedTouches[0].clientX-State._sx;
    if(dx<-40&&State.carouselIndex<State.events.length-1)State.carouselIndex++;
    else if(dx>40&&State.carouselIndex>0)State.carouselIndex--;
    updCarousel();
  };
}

function selEvt(id){
  var e=State.events.find(function(x){return x.id===id;});
  if(!e)return;

  // Members only check
  if(isMembersOnly(e)&&!userIsMember()){
    showMembersOnlyModal(e);return;
  }

  State.selectedEventId=id;
  document.querySelectorAll('.pc').forEach(function(c){c.classList.toggle('sel',c.dataset.id===id);});
  var ch=document.getElementById('cHint');
  if(ch){ch.textContent='✓ '+e.name+' seçildi';ch.className='c-hint ok';}
  var en2=document.getElementById('evtSelNone');if(en2)en2.style.display='none';
  var ed=document.getElementById('evtSelDot');if(ed)ed.style.display='block';
  var et=document.getElementById('evtSelTxt');
  if(et){et.style.display='block';et.innerHTML=_esc(e.name)+'<br><span style="font-size:9px;color:var(--muted)">'+fmtDate(e.date)+(e.time?' · '+e.time:'')+'</span>';}
  var nb=document.getElementById('evtNote');
  if(nb){if(e.note){nb.textContent=e.note;nb.style.display='block';}else nb.style.display='none';}

  // Guest mode note
  var gNote=document.getElementById('guestModeNote');
  if(!State.profile||!userIsMember()){
    if(!gNote){
      gNote=document.createElement('div');gNote.id='guestModeNote';
      gNote.style.cssText='background:rgba(201,168,76,.06);border:1px solid rgba(201,168,76,.15);border-left:3px solid var(--gold);border-radius:2px;padding:10px 14px;margin-bottom:14px;font-family:Space Mono,monospace;font-size:9px;color:var(--gold);line-height:1.8';
      var rulesWrap=document.getElementById('rulesWrap');
      rulesWrap.parentNode.insertBefore(gNote,rulesWrap);
    }
    gNote.textContent=t('guestNote');gNote.style.display='block';
  } else if(gNote){gNote.style.display='none';}

  // Auto-fill member data
  if(State.profile&&State.profile.status==='approved'){
    var fn=document.getElementById('fName');
    var fp=document.getElementById('fPhone');
    if(fn&&!fn.value)fn.value=State.profile.name||'';
    if(fp&&!fp.value)fp.value=State.profile.phone||'';
  }
  showRulesForLang(e);
  openSheet();
}

function showMembersOnlyModal(e){
