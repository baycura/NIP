function triggerAvatarUpload(){
  var inp=document.getElementById('avatarFileInput');if(inp)inp.click();
}
async function uploadAvatar(e){
  var f=e.target.files[0];if(!f)return;
  if(!State.session){toast('Giriş yapın');return;}
  toast('Fotoğraf yükleniyor...');
  compressAvatar(f,async function(b64){
    var res=await _SB.from('profiles').update({avatar_url:b64}).eq('id',State.session.user.id);
    if(res.error){toast('Hata: '+res.error.message);return;}
    toast('Profil fotoğrafı güncellendi ✓');
    await loadProfile();
    loadProfilePage();
  });
}
function compressAvatar(file,cb){
  var r=new FileReader();
  r.onload=function(ev){
    var img=new Image();
    img.onload=function(){
      var canvas=document.createElement('canvas');
      var size=200; // 200x200 thumbnail
      var w=img.width,h=img.height;
      var minDim=Math.min(w,h);
      var sx=(w-minDim)/2,sy=(h-minDim)/2;
      canvas.width=size;canvas.height=size;
      canvas.getContext('2d').drawImage(img,sx,sy,minDim,minDim,0,0,size,size);
      cb(canvas.toDataURL('image/jpeg',.72));
    };
    img.src=ev.target.result;
  };
  r.readAsDataURL(file);
}

