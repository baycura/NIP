      return '<div class="ledger-row"><div><div class="ledger-reason">'+(reasons[l.reason_code]||_esc(l.reason_code||'—'))+'</div><div class="t-mono" style="font-size:7px;color:var(--dim)">'+fmtDate(l.created_at?l.created_at.split('T')[0]:'')+'</div></div><div class="ledger-delta '+(l.delta>=0?'pos':'neg')+'">'+(l.delta>=0?'+':'')+l.delta+'</div></div>';
    }).join('')+'</div>':'')+'</div>';
}

