async function deleteMember(id,name,cid){
  if(!confirm(name+' kalıcı olarak silinsin mi?\n\nBu işlem geri alınamaz.'))return;
  // Delete from profiles (auth.users cascade will handle auth side IF we set up the cascade)
  // Also try to delete from auth directly via admin API
  await _SB.from('profiles').delete().eq('id',id);
  // Try auth delete (requires service role - will fail silently from client)
  toast(name+' silindi. Auth kaydını Supabase → Authentication → Users\'dan manuel silin.');
  if(cid==='recM'){renderRecM();renderAdminStats();}else{renderMStats();renderM();renderAdminStats();}
}
async function adjRep(profileId,type,delta,cid){
  var pRes=await _SB.from('profiles').select('trust_score,loyalty_score').eq('id',profileId).single();
  if(!pRes.data)return;
  var cur=type==='trust'?pRes.data.trust_score:pRes.data.loyalty_score;
  var newVal=Math.max(0,cur+delta);
  var upd={};upd[type+'_score']=newVal;
  // Recalc tier
  if(type==='trust'){
    upd.tier=newVal>=500?'elite':newVal>=300?'gold':newVal>=150?'silver':'bronze';
  }
  await _SB.from('profiles').update(upd).eq('id',profileId);
  await _SB.from('reputation_ledger').insert({profile_id:profileId,score_type:type,delta:delta,balance_after:newVal,reason_code:'admin_adjustment',source_type:'admin'}).catch(function(){});
  toast((delta>0?'+':'')+delta+' '+type);
  if(cid==='recM')renderRecM();else renderM();
}

