  if(ref){
    var ri=document.getElementById('refInput');if(ri){ri.value=ref.toUpperCase();checkRef(ref.toUpperCase());}
    G('s-register');
  }
})();

// ═══ UTILS ═══
function val(id){var e=document.getElementById(id);return e?e.value:'';}
function setErr(id,msg){var e=document.getElementById(id);if(e)e.textContent=msg;}
function toast(msg){
  var t=document.getElementById('toastEl');if(!t)return;
  t.textContent=msg;t.classList.add('show');
  clearTimeout(t._t);t._t=setTimeout(function(){t.classList.remove('show');},2800);
}
function setLoading(btnId,txtId,label,loading){
  var btn=document.getElementById(btnId),txt=document.getElementById(txtId);
  if(!btn)return;
  btn.disabled=loading;
  if(loading){if(txt)txt.innerHTML='<span class="spin-el"></span>';}
  else{if(txt)txt.textContent=label;}
}
function fmtDate(s){
  if(!s)return '';
  try{return new Date(s+'T12:00:00').toLocaleDateString('tr-TR',{day:'numeric',month:'long',year:'numeric'});}catch(e){return s;}
}
function randomHex(n){var r='';for(var i=0;i<n;i++)r+='0123456789abcdef'[Math.floor(Math.random()*16)];return r;}
function _esc(s){
  if(!s)return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;');
}
