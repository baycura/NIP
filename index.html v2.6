    ?'<img src="'+_esc(p.avatar_url)+'" style="width:64px;height:64px;border-radius:50%;object-fit:cover;border:2px solid '+tierColor+'">'
    :'<div style="width:64px;height:64px;border-radius:50%;background:var(--mid);border:2px solid '+tierColor+';display:flex;align-items:center;justify-content:center;font-size:24px">👤</div>')+
  '<div style="position:absolute;bottom:0;right:0;width:20px;height:20px;border-radius:50%;background:var(--black);border:1px solid var(--dim);display:flex;align-items:center;justify-content:center;font-size:10px;cursor:pointer">✏️</div>'+
  '</div>'+
  '<div style="flex:1">'+
  '<div style="font-family:CV,sans-serif;font-size:22px;letter-spacing:1px;line-height:1.1">'+_esc(p.name)+'</div>'+
  (p.member_code?'<div class="t-mono" style="font-size:8px;color:var(--muted);letter-spacing:2px;margin-top:3px">'+p.member_code+'</div>':'')+
  '<span class="tier-badge '+(TIER_COLORS[p.tier]||'tier-bronze')+'" style="font-size:9px;margin-top:6px;display:inline-block">'+tier+'</span>'+
  '</div></div>'+
  '<input type="file" id="avatarFileInput" accept="image/*" style="display:none" onchange="uploadAvatar(event)">'+

  // TIER PROGRESS
  '<div style="margin-bottom:20px">'+
  '<div style="display:flex;justify-content:space-between;margin-bottom:8px">'+
  '<span class="t-label">SEVİYE İLERLEMESİ</span>'+
  (p.tier!=='elite'?'<span class="t-mono" style="font-size:8px;color:var(--muted)">→ '+nextTier+': '+(tr2.max+1-p.trust_score)+' puan</span>':
  '<span class="t-mono" style="font-size:8px;color:var(--elite)">MAX SEVİYE ✓</span>')+
  '</div>'+
  '<div style="background:var(--dim);border-radius:2px;height:6px;overflow:hidden">'+
  '<div style="width:'+tierPct+'%;height:100%;background:'+tierColor+';border-radius:2px;transition:width 1s ease"></div>'+
  '</div>'+
  '<div style="display:flex;justify-content:space-between;margin-top:4px">'+
  '<span class="t-mono" style="font-size:7px;color:var(--muted)">'+tr2.min+'</span>'+
  '<span class="t-mono" style="font-size:7px;color:var(--muted)">'+(p.tier==='elite'?'∞':tr2.max)+'</span>'+
  '</div></div>'+

  // SCORE BARS
  scoreBar('PUAN',p.trust_score,500,tierColor,'/500')+
  scoreBar('SADAKAT',p.loyalty_score,1000,'var(--blue)','/1000')+
  scoreBar('DEVAM ORANI',attRate,100,'var(--green)','%')+

  // QUICK STATS
  '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px">'+
  '<div class="rep-stat"><div class="rep-num g">'+p.total_attended+'</div><div class="rep-lbl">KATILIM</div></div>'+
  '<div class="rep-stat"><div class="rep-num '+(p.attendance_streak>0?'gold':'')+'">'+p.attendance_streak+'</div><div class="rep-lbl">SERİ</div></div>'+
  '<div class="rep-stat"><div class="rep-num '+(p.total_no_show>0?'r':'g')+'">'+p.total_no_show+'</div><div class="rep-lbl">GELMEME</div></div>'+
  '</div></div>'+

  // REFERRAL
  (p.referral_code?'<div class="rep-card"><div class="t-label" style="margin-bottom:10px">REFERANS KODUN</div><div class="code-box">'+p.referral_code+'</div><div class="t-mono" style="font-size:8px;color:var(--muted);text-align:center;margin-top:6px">'+((p.referral_limit||3)-(p.referral_used||0))+' davet hakkı kaldı</div><button class="btn-sm" style="width:100%;margin-top:10px" onclick="copyRef()">🔗 Davet Linkini Kopyala</button></div>':'')+

  // LEDGER
  (ledger.data&&ledger.data.length?'<div class="rep-card"><div class="t-label" style="margin-bottom:12px">PUAN GEÇMİŞİ</div>'+
    ledger.data.map(function(l){
