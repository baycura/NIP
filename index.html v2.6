function rmP(){
  State.newPosterB64=null;
  var pp=document.getElementById('pPrev');if(pp)pp.style.display='none';
  var uz=document.getElementById('uZone');if(uz)uz.style.display='block';
}
function compressAndStore(file,cb){
  var r=new FileReader();
  r.onload=function(e){
    var img=new Image();
    img.onload=function(){
      var canvas=document.createElement('canvas');
      var maxW=800,maxH=1000,w=img.width,h=img.height;
      if(w>maxW){h=Math.round(h*maxW/w);w=maxW;}
      if(h>maxH){w=Math.round(w*maxH/h);h=maxH;}
      canvas.width=w;canvas.height=h;
      canvas.getContext('2d').drawImage(img,0,0,w,h);
      cb(canvas.toDataURL('image/jpeg',.78));
    };
    img.src=e.target.result;
  };
  r.readAsDataURL(file);
}

