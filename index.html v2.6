// ═══ QR SCAN ═══
async function startCam(){
  try{
    State.camStream=await navigator.mediaDevices.getUserMedia({video:{facingMode:'environment',width:{ideal:640},height:{ideal:640}}});
    var v=document.getElementById('qrVideo');v.srcObject=State.camStream;v.style.display='block';v.play();
    document.getElementById('camOff').style.display='none';
    document.getElementById('camOn').style.display='block';
    document.getElementById('qrRes').style.display='none';
    State.camTimer=setInterval(scanFrame,300);
  }catch(e){toast('Kamera erişimi reddedildi');}
}
function stopCam(){
  if(State.camStream){State.camStream.getTracks().forEach(function(t){t.stop();});State.camStream=null;}
  if(State.camTimer){clearInterval(State.camTimer);State.camTimer=null;}
  var v=document.getElementById('qrVideo');if(v){v.style.display='none';v.srcObject=null;}
  var co=document.getElementById('camOff');if(co)co.style.display='block';
  var cn=document.getElementById('camOn');if(cn)cn.style.display='none';
}
function scanFrame(){
  var v=document.getElementById('qrVideo');
  if(!v||v.readyState!==v.HAVE_ENOUGH_DATA)return;
  var c=document.getElementById('qrCanvas');c.width=v.videoWidth;c.height=v.videoHeight;
  var ctx=c.getContext('2d');ctx.drawImage(v,0,0,c.width,c.height);
  var img=ctx.getImageData(0,0,c.width,c.height);
  var code=jsQR(img.data,img.width,img.height,{inversionAttempts:'dontInvert'});
  if(code&&code.data&&code.data.startsWith('NIP-')){stopCam();document.getElementById('qrInput').value=code.data;scanQR();}
}
async function scanQR(){
  var inp=document.getElementById('qrInput').value.trim().toUpperCase();
  var res2=document.getElementById('qrRes');
  if(!inp){toast('QR kodu girin');return;}
  res2.style.display='block';res2.className='qr-res';res2.innerHTML='<div class="spin-el light" style="margin:0 auto"></div>';
  var res=await _SB.from('reservations').select('*').eq('qr_id',inp).single();
  var r=res.data;
  if(!r){res2.className='qr-res i';res2.innerHTML='<span class="qr-big">GEÇERSİZ</span>Kod bulunamadı.';return;}
  if(r.status==='used'){res2.className='qr-res u';res2.innerHTML='<span class="qr-big">KULLANILMIŞ</span>'+_esc(r.name)+'<br>Bu bilet zaten kullanıldı.';return;}
  if(r.status!=='approved'){res2.className='qr-res i';res2.innerHTML='<span class="qr-big">ONAYSIZ</span>'+_esc(r.name)+'<br>Durum: '+r.status;return;}
  // ATOMIC mark used
  await _SB.from('reservations').update({status:'used',checked_in_at:new Date().toISOString()}).eq('id',r.id);
  var streakMsg='';
  if(r.profile_id){
    var pRes=await _SB.from('profiles').select('trust_score,loyalty_score,total_attended,total_reservations,attendance_streak,max_streak,last_attended_at,tier').eq('id',r.profile_id).single();
    if(pRes.data){
      var pd=pRes.data;
      var trustDelta=20,loyaltyDelta=50,streakBonus=0;
      var lastAtt=pd.last_attended_at?new Date(pd.last_attended_at):null;
      var newStreak=1;
      if(lastAtt&&(new Date()-lastAtt)<45*24*3600*1000)newStreak=pd.attendance_streak+1;
      if(newStreak>=10)streakBonus=30;else if(newStreak>=5)streakBonus=15;else if(newStreak>=3)streakBonus=5;
      var newTrust=(pd.trust_score||100)+trustDelta+streakBonus;
      var newLoyalty=(pd.loyalty_score||0)+loyaltyDelta;
      var newTier=newTrust>=500?'elite':newTrust>=300?'gold':newTrust>=150?'silver':'bronze';
      await _SB.from('profiles').update({
        trust_score:newTrust,loyalty_score:newLoyalty,tier:newTier,
        total_attended:(pd.total_attended||0)+1,
        total_reservations:(pd.total_reservations||0)+1,
        attendance_streak:newStreak,max_streak:Math.max(pd.max_streak||0,newStreak),
        last_attended_at:new Date().toISOString()
      }).eq('id',r.profile_id);
      await _SB.from('reputation_ledger').insert([
        {profile_id:r.profile_id,score_type:'trust',delta:trustDelta+streakBonus,balance_after:newTrust,reason_code:'attended'+(streakBonus>0?'_streak':''),source_type:'event',source_id:r.event_id},
        {profile_id:r.profile_id,score_type:'loyalty',delta:loyaltyDelta,balance_after:newLoyalty,reason_code:'attended',source_type:'event',source_id:r.event_id}
      ]).catch(function(){});
      if(newStreak>=2)streakMsg='<div class="checkin-streak">🔥 '+newStreak+' GECELİK SERİ</div>';
      res2.className='qr-res v';
      res2.innerHTML='<span class="qr-big">GİRİŞ ✓</span>'+
        '<div class="checkin-card">'+
        '<span class="tier-badge '+(TIER_COLORS[newTier||'bronze']+' checkin-tier">')+((TIER_LABELS[State.lang]||TIER_LABELS.tr)[newTier||'bronze']||'')+'</span><br>'+
        '<strong style="font-family:CV,sans-serif;font-size:18px;letter-spacing:2px">'+_esc(r.name)+'</strong><br>'+
        _esc(r.event_name||'')+' · '+(r.guest_count||1)+' kişi'+
        (r.guest_names&&r.guest_names.length?'<div style="margin-top:8px;font-size:9px;color:var(--muted);letter-spacing:1px">'+r.guest_names.map(_esc).join(' · ')+'</div>':'')+
        streakMsg+'</div>';
    }
  } else {
    // Guest checkin
    res2.className='qr-res v';
    res2.innerHTML='<span class="qr-big">GİRİŞ ✓</span>'+_esc(r.name)+'<br>'+_esc(r.event_name||'')+' · '+(r.guest_count||1)+' kişi'+(r.guest_names&&r.guest_names.length?'<br><div style="font-size:9px;color:var(--muted);margin-top:6px">'+r.guest_names.map(_esc).join(' · ')+'</div>':'')+'<br><span style="font-size:8px;color:var(--muted)">MİSAFİR</span>';
  }
  document.getElementById('qrInput').value='';
}

// ═══ REALTIME ═══
_SB.channel('admin-global')
  .on('postgres_changes',{event:'*',schema:'public',table:'profiles'},function(){
    if(document.getElementById('ap-mb').classList.contains('active')){renderMStats();renderM();}
    if(document.getElementById('ap-ov').classList.contains('active')){renderAdminStats();renderRecM();}
  })
  .on('postgres_changes',{event:'*',schema:'public',table:'reservations'},function(){
    if(document.getElementById('ap-rs').classList.contains('active'))renderRes();
    if(document.getElementById('ap-ov').classList.contains('active')){renderAdminStats();renderRecR();}
  })
  .subscribe();

